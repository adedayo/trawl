# Trawl — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ─── Required ───────────────────────────────────────────────────────────────────

# LLM API key (any OpenAI-compatible provider)
# Leave empty if using a local model (Ollama/vLLM/llama.cpp)
LLM_API_KEY=

# Seed domains to monitor (comma-separated)
SEED_DOMAINS=example.com

# ─── Optional ───────────────────────────────────────────────────────────────────

# Seed CIDRs to monitor (comma-separated)
SEED_CIDRS=

# Public repositories to scan for secrets (comma-separated URLs)
SEED_REPOS=

# Alert webhook URL (Slack incoming webhook or compatible)
WEBHOOK_URL=

# Convex deployment URL (set automatically by `npx convex dev`)
CONVEX_URL=

# Shodan API key (optional, for discovery enrichment)
SHODAN_API_KEY=

# Censys API credentials (optional, for discovery enrichment)
CENSYS_API_ID=
CENSYS_API_SECRET=
